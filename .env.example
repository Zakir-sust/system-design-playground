# =====================================================================
#  .env TEMPLATE  —  copy this into a project as ".env" and fill it in.
#
#   cp ../.env.example .env      (run from inside a project folder)
#
#  Your real ".env" is git-ignored and must NEVER be committed.
#  These are LOCAL development values only. Each project uses the
#  subset of variables it actually needs — delete the rest.
# =====================================================================

# ---- PostgreSQL (most projects) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=appdb
# The API reads this; the double underscore maps to ConnectionStrings:Default
ConnectionStrings__Default=Host=db;Port=5432;Database=appdb;Username=app;Password=change_me_locally

# ---- Redis (02 cache, 03 rate-limiter, 14 backplane, …) ----
REDIS_CONNECTION=redis:6379

# ---- RabbitMQ (04 broker, 05 outbox, 12 notifications, 22 saga) ----
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq

# ---- MinIO / object storage (07 blob, 11 pastebin, 13 images, 25 video) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_locally
MINIO_ENDPOINT=minio:9000

# ---- Elasticsearch (08 search, 18 autocomplete) ----
ELASTIC_URI=http://elasticsearch:9200

# ---- Seq structured logs (00 onward, optional) ----
SEQ_URL=http://seq:5341

# ---- Cloud (Phase 5) — leave BLANK locally; use Key Vault in the cloud ----
# AZURE_STORAGE_CONNECTION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
