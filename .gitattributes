# Normalize line endings: store as LF in the repo, check out native on each OS.
# Prevents noisy CRLF/LF diffs across macOS/Windows/Linux.
* text=auto eol=lf

# Shell scripts must stay LF even on Windows checkouts
*.sh text eol=lf

# Treat common binaries as binary (no diff/merge munging)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.mp4  binary
*.zip  binary
